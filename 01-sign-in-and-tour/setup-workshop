#!/bin/bash
# Defensive per-challenge setup for 01-sign-in-and-tour.
# Re-validates the Coder stack is healthy in case the learner paused or jumped ahead.
set -uo pipefail

CODER_ACCESS_URL="https://workshop-80-${_SANDBOX_ID}.env.play.instruqt.com"

code=$(curl -s -o /dev/null -w "%{http_code}" "${CODER_ACCESS_URL}/healthz" || echo "000")
if ! echo "$code" | grep -qE "^(200|404)$"; then
  echo "Coder health check failed (code ${code}); waiting for stack..."
  n=0
  until [ "$n" -ge 30 ]; do
    code=$(curl -s -o /dev/null -w "%{http_code}" "${CODER_ACCESS_URL}/healthz" || echo "000")
    if echo "$code" | grep -qE "^(200|404)$"; then break; fi
    n=$((n+1)); sleep 3
  done
fi

if [ ! -s /etc/coder/admin.token ]; then
  echo "WARNING: /etc/coder/admin.token missing — check script may not be able to validate via API."
fi

# ──────────────────────────────────────────────────────────────────────────────
# Personalize the workshop identity to the real participant (claim-time).
# Runs in THIS challenge setup, NOT track setup: per Instruqt docs, INSTRUQT_USER_* are
# empty in a Hot Start TRACK setup but populated in a CHALLENGE setup once the participant
# has claimed the sandbox (and consented to share details). We paint the participant's real
# email + full name onto the Gitea 'learner' account; on first "Sign in with Gitea", Coder
# JIT-creates the user from those OIDC claims, so the Coder identity carries the real name.
# The Coder USERNAME is derived from the name claim (CODER_OIDC_USERNAME_FIELD=name): Coder's
# UsernameFrom() strips disallowed chars, so "John Smith" -> "JohnSmith".
# Consent-gated: if the email is absent (no consent / non-invite access), we DON'T personalize —
# the account keeps its default 'learner' name, so Coder derives the username 'learner'.
# ──────────────────────────────────────────────────────────────────────────────
PARTICIPANT_EMAIL="$(printenv INSTRUQT_USER_EMAIL 2>/dev/null || true)"
PARTICIPANT_NAME="$(printenv INSTRUQT_USER_NAME 2>/dev/null || true)"
CONSENT="$(printenv INSTRUQT_PRIVACY_POLICY_CONSENT 2>/dev/null || true)"

if [ -z "${PARTICIPANT_EMAIL}" ]; then
  # No consent / non-invite access: do NOT invent a fallback identity. Leaving the Gitea
  # 'learner' account untouched means its name claim stays 'learner', so Coder derives the
  # default username 'learner' — exactly the intended fallback.
  echo "C01: no participant email (consent=${CONSENT:-unknown}); keeping default 'learner' identity."
else
  if [ -z "${PARTICIPANT_NAME}" ]; then
    # Details shared but name missing: derive a presentable name from the email local-part
    # ("jane.doe" -> "Jane Doe"), which in turn yields a CamelCase Coder username ("JaneDoe").
    PARTICIPANT_NAME="$(printf '%s' "${PARTICIPANT_EMAIL%@*}" | tr '._-' '   ' \
      | awk '{for(i=1;i<=NF;i++){$i=toupper(substr($i,1,1)) substr($i,2)}}1')"
  fi
  echo "C01: workshop identity -> ${PARTICIPANT_NAME} <${PARTICIPANT_EMAIL}>"

  # PATCH the Gitea 'learner' account via the coder container (curl -> gitea:3000 direct),
  # bypassing Caddy's forced X-WEBAUTH-USER header so the gitadmin basic-auth applies.
  LEARNER_USERNAME="$(agent variable get GITEA_USERNAME 2>/dev/null || echo learner)"
  cx() { docker compose -f /etc/coder/docker-compose.yml exec -T coder curl "$@"; }
  . /etc/coder/gitea-admin.cred 2>/dev/null || echo "C01: gitea-admin.cred missing; identity not personalized."
  if [ -n "${GITEA_ADMIN_USERNAME:-}" ] && [ -n "${GITEA_ADMIN_PASSWORD:-}" ]; then
    # login_name + source_id (0 = local) are sent for compatibility with older Gitea admin API.
    PATCH_CODE=$(jq -n --arg e "$PARTICIPANT_EMAIL" --arg n "$PARTICIPANT_NAME" --arg ln "$LEARNER_USERNAME" \
                  '{email:$e, full_name:$n, login_name:$ln, source_id:0}' \
      | cx -s -o /dev/null -w "%{http_code}" -X PATCH "http://gitea:3000/api/v1/admin/users/${LEARNER_USERNAME}" \
            -u "${GITEA_ADMIN_USERNAME}:${GITEA_ADMIN_PASSWORD}" -H "Content-Type: application/json" -d @- 2>/dev/null)
    echo "C01: personalized Gitea '${LEARNER_USERNAME}' (HTTP ${PATCH_CODE})"
  fi
fi

# Grant the non-owner learner(s) the read-only 'auditor' site role (per Jason 2026-06-17:
# applied in EVERY challenge so the learner always holds the read-only auditor seat, e.g.
# to open Admin settings -> AI Sessions). auditor is read-only and exposes no secrets
# (provider creds / MCP PAT / OAuth secret are write-only in Coder). Idempotent.
ADMIN_TOK=$(cat /etc/coder/admin.token 2>/dev/null | tr -d '\r\n')
if [ -n "${ADMIN_TOK}" ]; then
  curl -s -H "Coder-Session-Token: ${ADMIN_TOK}" "http://localhost/api/v2/users" 2>/dev/null \
    | jq -r '.users[]? | select(.username != "admin" and .username != "ci-bot") | .id' 2>/dev/null \
    | while read -r MID; do
        [ -z "${MID}" ] && continue
        code=$(curl -s -o /dev/null -w "%{http_code}" -X PUT \
          "http://localhost/api/v2/users/${MID}/roles" \
          -H "Coder-Session-Token: ${ADMIN_TOK}" -H "Content-Type: application/json" \
          -d '{"roles":["auditor"]}' || echo "000")
        echo "C01: granted auditor to ${MID} (HTTP ${code})"
      done
else
  echo "C01: admin token not found; auditor grant skipped."
fi
