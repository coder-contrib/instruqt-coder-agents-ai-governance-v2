wait_in_coder "${GITEA_INT}/" 90 3 || echo "WARN: Gitea readiness gate timed out; continuing."
wait_in_coder "${GRAFANA_INT}/api/health" 60 3 || true
echo "--- coder logs (tail 40) ---"; docker compose logs --tail=40 coder 2>&1 || true

# ──────────────────────────────────────────────────────────────────────────────
# Coder: first admin (TRIAL — unlocks AI Gateway), per the prospect's scaffolding
# ──────────────────────────────────────────────────────────────────────────────
CODER_ADMIN_EMAIL="admin@example.com"
CODER_ADMIN_USERNAME="admin"
CODER_ADMIN_PASSWORD="CoderAdmin-$(date +%s | tail -c 6)!aA"

# No local learner account is created. Learners authenticate via Gitea OIDC (configured as
# Coder's login provider in the Gitea block below), and Coder just-in-time creates their
# user on first sign-in (CODER_OIDC_ALLOW_SIGNUPS=true). C01's challenge setup paints the
# participant's real email + name onto the Gitea 'learner' account first, so the JIT-created
# Coder identity carries the real identity (see 01-sign-in-and-tour/setup-workshop). The
# provisioning admin below stays password-based, which is why password auth is left enabled.

FIRST_USER_BODY=$(jq -n --arg email "$CODER_ADMIN_EMAIL" --arg username "$CODER_ADMIN_USERNAME" --arg password "$CODER_ADMIN_PASSWORD" \
  '{email: $email, username: $username, name: "Admin User", password: $password, trial: true,
    trial_info: {first_name: "Admin", last_name: "User", phone_number: "555-555-5555",
                 job_title: "Platform Engineer", company_name: "Example Corp", country: "US", developers: "1-50"}}')
FIRST_USER_RESP=$(printf '%s' "$FIRST_USER_BODY" | cx -s -X POST "${CODER_INT}/api/v2/users/first" -H "Content-Type: application/json" -d @-)
echo "first-user response: ${FIRST_USER_RESP}" | head -c 300; echo

LOGIN_BODY=$(jq -n --arg email "$CODER_ADMIN_EMAIL" --arg pw "$CODER_ADMIN_PASSWORD" '{email: $email, password: $pw}')
LOGIN_RESP=$(printf '%s' "$LOGIN_BODY" | cx -s -X POST "${CODER_INT}/api/v2/users/login" -H "Content-Type: application/json" -d @-)
CODER_ADMIN_TOKEN=$(echo "$LOGIN_RESP" | jq -r '.session_token')
if [ -z "$CODER_ADMIN_TOKEN" ] || [ "$CODER_ADMIN_TOKEN" = "null" ]; then
  echo "FATAL: no admin session token. ${LOGIN_RESP}" >&2; exit 1; fi
echo "Coder admin token obtained."

ORG_RESP=$(cx -s -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" "${CODER_INT}/api/v2/organizations")
DEFAULT_ORG_ID=$(echo "$ORG_RESP" | jq -r '.[0].id // empty')
[ -z "$DEFAULT_ORG_ID" ] && { echo "FATAL: no default org. ${ORG_RESP}" >&2; exit 1; }
echo "Org ID: ${DEFAULT_ORG_ID}"

# ──────────────────────────────────────────────────────────────────────────────
# CI identity: a dedicated 'ci-bot' user (NOT admin), so the C04 CI-triggered chat is
# attributed to a distinct machine identity in the C06 audit — the learner's GitHub/Gitea
# identity beside 'ci-bot', rather than beside 'admin'. ci-bot's token becomes the CI
# session token the Gitea Actions workflow uses (minted just below, after the template push).
# ──────────────────────────────────────────────────────────────────────────────
CI_BOT_USERNAME="ci-bot"
# Capture ci-bot's password so the CI token can be minted by logging in AS ci-bot below.
# Minting a token for another user via the admin session can be refused by Coder (owners
# are not always permitted to create API keys for other users). That would fall back to the
# admin token and reattribute C04's CI chat to 'admin', the exact bug this identity split
# fixes, so we log in as ci-bot to mint instead and keep admin-mint only as a last resort.
CI_BOT_PASSWORD="CiBot-$(date +%s | tail -c 6)!aA"
CI_BOT_RESP=$(cx -sS -w $'\n%{http_code}' -X POST "${CODER_INT}/api/v2/users" \
  -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg o "$DEFAULT_ORG_ID" --arg p "$CI_BOT_PASSWORD" \
        '{email:"ci-bot@coder.local", username:"ci-bot", name:"CI Bot", password:$p, login_type:"password", organization_ids:[$o]}')")
CI_BOT_HTTP=$(echo "${CI_BOT_RESP}" | tail -n1)
CI_BOT_ID=$(echo "${CI_BOT_RESP}" | sed '$d' | jq -r '.id // empty')
echo "ci-bot create HTTP ${CI_BOT_HTTP} (id=${CI_BOT_ID:-none})"

# Grant ci-bot the built-in 'agents-access' role so its API-triggered chats run. chat:read
# is sufficient; ci-bot deliberately does NOT get auditor (least-privilege machine identity).
if [ -n "${CI_BOT_ID}" ]; then
  printf '%s' '{"roles": ["agents-access"]}' \
    | cx -s -o /dev/null -X PUT "${CODER_INT}/api/v2/organizations/${DEFAULT_ORG_ID}/members/${CI_BOT_ID}/roles" \
        -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" -H "Content-Type: application/json" -d @- || true
fi

# ──────────────────────────────────────────────────────────────────────────────
# Admin-UI fallback target values (printed for the presenter if any automation slips)
# ──────────────────────────────────────────────────────────────────────────────
cat <<DIAGEOF
=== Coder Agents / AI Gateway config targets (admin-UI fallback) ===
  GitHub login:   custom OAuth app (device flow); ALLOW_EVERYONE; signups on
  AI Gateway providers (Admin → AI → Providers, or /ai/settings):
    - Bedrock (type=bedrock): region ${CLAUDE_REGION}; model ${BEDROCK_SONNET_MODEL}; small/fast ${BEDROCK_HAIKU_MODEL}; AWS access key/secret in settings
    - OpenAI-compatible:    base URL https://bedrock-runtime.${GPTOSS_REGION}.amazonaws.com/openai/v1 ; model ${BEDROCK_GPTOSS_MODEL}; Bedrock API key (bearer)
  Coder Agents models:  ${BEDROCK_SONNET_MODEL} (default) + ${BEDROCK_HAIKU_MODEL} + ${BEDROCK_GPTOSS_MODEL}
  Spend cap (advisory): ${SPEND_CAP_USD_PER_DAY} USD/user/day  — UI-only, NOT auto-enforced; needs per-model pricing too (see NOTE). Monitor via Grafana + AWS.
  GitHub MCP:       Manage Agents → MCP Servers → https://api.githubcopilot.com/mcp/  (PAT bearer)
  Learner role:     Coder Agents User + Auditor (read-only)  (auto-granted to each GitHub user via systemd reconciler + C01 check)
====================================================================
DIAGEOF

# ──────────────────────────────────────────────────────────────────────────────
# Coder Agents (v2.34) model wiring — ENTIRELY BEST-EFFORT. errexit + pipefail are
# DISABLED for this whole block so a 4xx, a wrong-schema body, or a truncated-response
# SIGPIPE can NEVER abort setup (a prior run died exit 255 exactly this way). Every
# call's HTTP code + full body is logged for diagnosis (no `head` truncation).
#
# CONFIRMED 2026-06-15 (with Coder's team): the Claude provider MUST be created as
# TYPE=bedrock via the REST API (POST /api/v2/ai/providers). A TYPE=anthropic provider
# with bedrock settings does NOT surface its models in the Agents chat dropdown. Required
# fields: type, name, base_url, enabled, settings{_type:"bedrock",_version:1,model,
# small_fast_model,region,access_key,access_key_secret}. gpt-oss stays env-seeded
# (TYPE=openai) and is resolved by name. model-configs POST returns 201.
# ──────────────────────────────────────────────────────────────────────────────
set +e +o pipefail

# (a) Create the Claude provider as TYPE=bedrock via REST (the only shape the Agents
#     dropdown surfaces). base_url + settings._type discriminator are both required.
set +x
echo "POST bedrock provider (TYPE=bedrock):"
jq -n --arg bu "https://bedrock-runtime.${CLAUDE_REGION}.amazonaws.com" \
      --arg m "${BEDROCK_SONNET_MODEL}" --arg sf "${BEDROCK_HAIKU_MODEL}" --arg r "${CLAUDE_REGION}" \
      --arg ak "${AWS_ACCESS_KEY_ID_VAL}" --arg as "${AWS_SECRET_ACCESS_KEY_VAL}" \
      '{type:"bedrock", name:"bedrock-claude", display_name:"AWS Bedrock (Claude)", enabled:true, base_url:$bu, settings:{_type:"bedrock", _version:1, base_url:$bu, model:$m, small_fast_model:$sf, region:$r, access_key:$ak, access_key_secret:$as}}' \
  | cx -s -w "\nHTTP %{http_code}\n" -X POST "${CODER_INT}/api/v2/ai/providers" \
      -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" -H "Content-Type: application/json" -d @- 2>&1
set -x

# Resolve provider ids: Claude (just-created bedrock provider) + gpt-oss (env-seeded), both by name.
PROVIDERS_JSON=$(cx -s -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" "${CODER_INT}/api/v2/ai/providers")
CLAUDE_PID=$(echo "$PROVIDERS_JSON" | jq -r '.[]|select(.name=="bedrock-claude")|.id // empty')
GPTOSS_PID=$(echo "$PROVIDERS_JSON" | jq -r '.[]|select(.name=="bedrock-gptoss")|.id // empty')
echo "Agents providers: claude=${CLAUDE_PID:-none} gptoss=${GPTOSS_PID:-none}"

# (b) Create model-configs (the chat's dropdown list). Confirmed 201 last run.
add_model() {  # $1 provider_id  $2 model_id  $3 display  $4 is_default(true/false)
  [ -z "$1" ] && { echo "skip model ${2} (no provider id)"; return 0; }
  echo "model-config ${3} (${2}):"
  jq -n --arg pid "$1" --arg m "$2" --arg d "$3" --argjson def "$4" \
    '{ai_provider_id:$pid, model:$m, display_name:$d, enabled:true, is_default:$def, context_limit:200000}' \
    | cx -s -w "\nHTTP %{http_code}\n" -X POST "${CODER_INT}/api/experimental/chats/model-configs" \
        -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" -H "Content-Type: application/json" -d @- 2>&1
}
add_model "${CLAUDE_PID}" "${BEDROCK_SONNET_MODEL}" "Claude Sonnet 4.6"   true
add_model "${CLAUDE_PID}" "${BEDROCK_HAIKU_MODEL}"  "Claude Haiku 4.5"    false
add_model "${GPTOSS_PID}" "${BEDROCK_GPTOSS_MODEL}" "OpenAI gpt-oss-120b" false

# GitHub MCP server. Schema confirmed from Coder source codersdk/mcp.go
# (CreateMCPServerConfigRequest) on 2026-06-14, corroborated field-for-field by the live
# v2.34.x API: transport one of {streamable_http, sse}; auth_type one of {none, oauth2,
# api_key, custom_headers, user_oidc}; availability one of {force_on, default_on,
# default_off}; the PAT
# is passed via api_key_header + api_key_value (NOT a `headers` map). Prior 400s were
# transport:"streamable-http" (hyphen) + auth_type:"bearer" + headers — all invalid.
# SECURITY: disable xtrace BEFORE referencing the PAT. The 'if [ -n "$PAT" ]' condition test
# is itself traced and prints the expanded token, so set +x MUST precede the if, not follow then.
set +x

set -x
set -e -o pipefail
# NOTE — spend cap is ADVISORY, NOT auto-enforced (decision 2026-06-17, grounded in
# Coder docs: ai-coder/agents/platform-controls/usage-insights). Coder exposes NO API/CLI
# to set the spend limit — it is UI-only: Agents > Settings > Manage Agents > Spend
# (enable; Period=day; Default limit=${SPEND_CAP_USD_PER_DAY}). Enforcement ALSO requires
# per-model input/output pricing (Agents > Settings > Manage Agents > Models) for EVERY
# enabled Bedrock model; until BOTH are set, Coder's limit fail-opens for Bedrock. For these
# ephemeral sandboxes (no per-play admin) we rely on MONITORING instead — the Grafana cost
# table (LiteLLM pricing) + AWS billing — and enable only the 3 approved models.
# (AI Gateway rate/concurrency controls are request throttles, not dollar caps.)

# ──────────────────────────────────────────────────────────────────────────────
# Custom workspace template (Docker; Node 22; repo pre-clone from in-sandbox Gitea)
# ──────────────────────────────────────────────────────────────────────────────
mkdir -p /etc/coder/workspace-template
cat > /etc/coder/workspace-template/main.tf <<'TFTEMPLATE'
terraform {
  required_providers {
    coder  = { source = "coder/coder" }
    docker = { source = "kreuzwerker/docker" }
  }
}
variable "docker_socket" {
  default = ""
  type    = string
}
provider "docker" {
  host = var.docker_socket != "" ? var.docker_socket : null
}
data "coder_provisioner" "me" {}
data "coder_workspace" "me" {}
data "coder_workspace_owner" "me" {}
resource "coder_agent" "main" {
  arch = data.coder_provisioner.me.arch
  os   = "linux"
  startup_script_behavior = "blocking"
  startup_script = <<-EOT
    set -e
    if [ ! -f ~/.init_done ]; then cp -rT /etc/skel ~ 2>/dev/null || true; touch ~/.init_done; fi
    if ! command -v node >/dev/null 2>&1 || [ "$(node --version 2>/dev/null | cut -d. -f1)" != "v22" ]; then
      curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash -; sudo apt-get install -y nodejs; fi
    if [ ! -d /home/coder/memory-card-ai-demo ]; then
      cd /home/coder
      git clone http://learner:WorkshopL3arner!@host.docker.internal:8081/learner/memory-card-ai-demo.git; fi
    cd /home/coder/memory-card-ai-demo
    git config --global user.name "${coalesce(data.coder_workspace_owner.me.full_name, data.coder_workspace_owner.me.name)}"
    git config --global user.email "${data.coder_workspace_owner.me.email}"
    if grep -q 'rolldown-vite' package.json; then sed -i 's/"npm:rolldown-vite@7\.1\.14"/"^5.0.4"/g' package.json; fi
    if [ ! -d node_modules ]; then npm install --no-audit --no-fund; fi
    # App Preview: allow the Instruqt sandbox host in Vite, hide that tweak from git so it
    # never lands in the agent's PR, then start the Vite dev server (5173) in the background
    # so the published port serves the live working tree.
    perl -0777 -pi -e 's/allowedHosts:\s*\[[^\]]*\]/allowedHosts: true/s' vite.config.js 2>/dev/null || true
    git update-index --assume-unchanged vite.config.js 2>/dev/null || true
    if ! curl -fsS http://localhost:5173 >/dev/null 2>&1; then nohup npm run dev > /tmp/vite-dev.log 2>&1 & fi
    touch /home/coder/.workspace-ready
    if [ ! -f /etc/profile.d/workshop-cwd.sh ]; then
      echo 'cd /home/coder/memory-card-ai-demo 2>/dev/null || true' | sudo tee /etc/profile.d/workshop-cwd.sh >/dev/null
      sudo chmod +x /etc/profile.d/workshop-cwd.sh; fi
    echo "Workspace ready: Node $(node --version)."
  EOT
  env = {
    GIT_AUTHOR_NAME     = coalesce(data.coder_workspace_owner.me.full_name, data.coder_workspace_owner.me.name)
    GIT_AUTHOR_EMAIL    = data.coder_workspace_owner.me.email
    GIT_COMMITTER_NAME  = coalesce(data.coder_workspace_owner.me.full_name, data.coder_workspace_owner.me.name)
    GIT_COMMITTER_EMAIL = data.coder_workspace_owner.me.email
