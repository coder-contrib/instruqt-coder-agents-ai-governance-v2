}
module "code-server" {
  source   = "registry.coder.com/coder/code-server/coder"
  version  = "~> 1.0"
  agent_id = coder_agent.main.id
}
resource "docker_volume" "home_volume" {
  name = "coder-${data.coder_workspace.me.id}-home"
  lifecycle { ignore_changes = all }
}
resource "docker_container" "workspace" {
  count    = data.coder_workspace.me.start_count
  image    = "codercom/enterprise-base:ubuntu"
  name     = "coder-${data.coder_workspace_owner.me.name}-${lower(data.coder_workspace.me.name)}"
  hostname = data.coder_workspace.me.name
  command  = ["sh", "-c", replace(coder_agent.main.init_script, "/localhost|127\\.0\\.0\\.1/", "host.docker.internal")]
  env      = ["CODER_AGENT_TOKEN=${coder_agent.main.token}"]
  host {
    host = "host.docker.internal"
    ip   = "host-gateway"
  }
  volumes {
    container_path = "/home/coder/"
    volume_name    = docker_volume.home_volume.name
    read_only      = false
  }
  # App Preview: publish the in-workspace Vite dev server (5173) to the VM host so an
  # Instruqt service tab can reach it. ONLY the human learner's workspace publishes it. Any
  # machine-owned workspace (the provisioning 'admin', and the C04 CI-triggered 'ci-bot')
  # must NOT also bind host:5173, or the two workspaces collide on the fixed port and the
  # second one fails to start with a terraform apply error (in C04 that means no PR). The
  # CI workspace only opens a PR, so it never needs the preview port anyway.
  dynamic "ports" {
    for_each = contains(["admin", "ci-bot"], data.coder_workspace_owner.me.name) ? [] : [1]
    content {
      internal = 5173
      external = 5173
      ip       = "0.0.0.0"
    }
  }
}
TFTEMPLATE

if docker compose -f /etc/coder/docker-compose.yml exec -T -u 0 coder coder login "http://localhost:7080" --token "${CODER_ADMIN_TOKEN}" \
   && docker compose -f /etc/coder/docker-compose.yml exec -T -u 0 coder bash -c 'rm -rf /tmp/docker-template && mkdir -p /tmp/docker-template' \
   && docker cp /etc/coder/workspace-template/main.tf "$(docker compose -f /etc/coder/docker-compose.yml ps -q coder)":/tmp/docker-template/main.tf \
   && docker compose -f /etc/coder/docker-compose.yml exec -T -u 0 coder bash -c 'cd /tmp/docker-template && coder templates push docker --yes --directory .'; then
  echo "Workspace template registered: docker"
else
  echo "WARN: workspace template push failed; admin can retry from Templates UI." >&2
fi

# Mint the CI session token AS ci-bot (created above) for the C04 CI workflow's headless
# Agents API calls, so the CI-triggered chat is attributed to ci-bot, not admin. Preferred
# path: log in as ci-bot with its own password and mint the token on its own session, which
# always carries the right owner. Fallbacks: admin mints on ci-bot's behalf, then the admin
# token itself. Only the last resort reattributes CI to admin, and it says so loudly.
CODER_CI_TOKEN=""
CI_BOT_LOGIN=$(printf '%s' "$(jq -n --arg e "${CI_BOT_EMAIL:-ci-bot@coder.local}" --arg p "$CI_BOT_PASSWORD" '{email:$e, password:$p}')" \
  | cx -s -X POST "${CODER_INT}/api/v2/users/login" -H "Content-Type: application/json" -d @-)
CI_BOT_TOKEN=$(echo "$CI_BOT_LOGIN" | jq -r '.session_token // empty')
if [ -n "${CI_BOT_TOKEN}" ]; then
  CI_TOKEN_RESP=$(printf '%s' '{"token_name":"ci-agent-token","scope":"all"}' \
    | cx -s -X POST "${CODER_INT}/api/v2/users/${CI_BOT_USERNAME}/keys/tokens" \
        -H "Coder-Session-Token: ${CI_BOT_TOKEN}" -H "Content-Type: application/json" -d @-)
  CODER_CI_TOKEN=$(echo "$CI_TOKEN_RESP" | jq -r '.key // empty')
fi
if [ -z "${CODER_CI_TOKEN}" ]; then
  # Fallback 1: admin mints on ci-bot's behalf (works on Coder versions that allow it).
  CI_TOKEN_RESP=$(printf '%s' '{"token_name":"ci-agent-token","scope":"all"}' \
    | cx -s -X POST "${CODER_INT}/api/v2/users/${CI_BOT_USERNAME}/keys/tokens" \
        -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" -H "Content-Type: application/json" -d @-)
  CODER_CI_TOKEN=$(echo "$CI_TOKEN_RESP" | jq -r '.key // empty')
fi
[ -z "${CODER_CI_TOKEN}" ] && { CODER_CI_TOKEN="${CODER_ADMIN_TOKEN}"; echo "WARN: ci-bot token mint failed (login and admin-mint both failed); using admin token for CI (C06 will attribute CI to admin)."; }

# ──────────────────────────────────────────────────────────────────────────────
# agents-access reconciler — systemd service (survives challenge transitions)
# ──────────────────────────────────────────────────────────────────────────────
# Grants the built-in 'agents-access' (Coder Agents User) role to EVERY non-admin
# (GitHub-authed) user that lacks it, so the Agents UI + model dropdown appear with
# NO manual grant. This is exactly the design the Build Plan specifies ("a reconciler
# from setup-workshop that waits for the first non-admin user to appear and grants
# them agents-access").
#
# NOTE: the read-only 'auditor' SITE role (needed ONLY for C06's AI Sessions view) is
# granted later, in 06-ai-gateway-and-grafana/setup-workshop — least-privilege, so the
# learner has NO admin-settings visibility during C01-C05 and steps into the read-only
# auditor seat exactly when C06 needs it. (auditor exposes no secrets: provider creds /
# MCP PAT / OAuth secret are write-only in Coder and never returned, even to owner.) Empirically (2026-06-14) agents-access alone surfaces the
# model dropdown — chat:read is sufficient; no broader role is needed (and Coder
# forbids custom org roles from carrying these org_member perms anyway: HTTP 400
# "organization scoped roles may not contain organization member permissions").
#
# Why systemd, not nohup: the old nohup poller (a) timed out after ~20 min and
# (b) did not survive Instruqt challenge transitions, so a learner who signed in
# late got no grant and had to run it manually. A systemd service with Restart=always
# loops indefinitely and catches the login whenever it happens. A per-user state file
# means each user is granted exactly once (no redundant PUTs, no log spam).
cat > /usr/local/bin/agents-access-reconciler.sh <<RECEOF
#!/bin/bash
ORG="${DEFAULT_ORG_ID}"
COMPOSE="/etc/coder/docker-compose.yml"
STATE="/var/lib/agents-access-granted"
touch "\${STATE}"
ccurl() { docker compose -f "\${COMPOSE}" exec -T coder curl -s "\$@"; }
while true; do
  TOKEN="\$(cat /etc/coder/admin.token 2>/dev/null)"
  if [ -n "\${TOKEN}" ]; then
    ccurl -H "Coder-Session-Token: \${TOKEN}" "http://localhost:7080/api/v2/users" \
      | jq -r '.users[]? | select(.username != "admin" and .username != "ci-bot") | .id' 2>/dev/null \
      | while read -r MEMBER_ID; do
          [ -z "\${MEMBER_ID}" ] && continue
          grep -qxF "\${MEMBER_ID}" "\${STATE}" && continue
          CODE=\$(printf '%s' '{"roles": ["agents-access"]}' \
            | ccurl -o /dev/null -w "%{http_code}" \
                -X PUT "http://localhost:7080/api/v2/organizations/\${ORG}/members/\${MEMBER_ID}/roles" \
                -H "Coder-Session-Token: \${TOKEN}" -H "Content-Type: application/json" -d @-)
          # Also grant the read-only 'auditor' SITE role (unlocks Admin settings -> AI
          # Sessions). Same post-sign-in timing as agents-access, so it lives here too: a
          # per-challenge setup grant can't fire in C01 (setup runs before the learner logs in).
          ACODE=\$(printf '%s' '{"roles": ["auditor"]}' \
            | ccurl -o /dev/null -w "%{http_code}" \
                -X PUT "http://localhost:7080/api/v2/users/\${MEMBER_ID}/roles" \
                -H "Coder-Session-Token: \${TOKEN}" -H "Content-Type: application/json" -d @-)
          if [[ "\${CODE}" == 2* ]] && [[ "\${ACODE}" == 2* ]]; then
            echo "\${MEMBER_ID}" >> "\${STATE}"
            echo "granted agents-access + auditor to \${MEMBER_ID} (org \${CODE} / site \${ACODE})"
          else
            echo "grant for \${MEMBER_ID} returned org \${CODE} / site \${ACODE} (will retry)"
          fi
        done
  fi
  sleep 5
done
RECEOF
chmod +x /usr/local/bin/agents-access-reconciler.sh

cat > /etc/systemd/system/agents-access-reconciler.service <<'UNITEOF'
[Unit]
Description=Coder agents-access role reconciler (auto-grant to GitHub learners)
After=docker.service
Wants=docker.service

[Service]
Type=simple
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/local/bin/agents-access-reconciler.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
systemctl enable --now agents-access-reconciler.service
echo "agents-access reconciler (systemd) enabled."

# ──────────────────────────────────────────────────────────────────────────────
# Postgres: read-only role for Grafana
# ──────────────────────────────────────────────────────────────────────────────
docker compose -f /etc/coder/docker-compose.yml exec -T postgres \
  psql -U coder -d coder -v ON_ERROR_STOP=0 <<'PSQL' || echo "WARN: grafana_ro provisioning had non-fatal errors."
DO $$ BEGIN
  IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname='grafana_ro') THEN CREATE ROLE grafana_ro LOGIN PASSWORD 'grafana_ro_pw'; END IF;
END $$;
GRANT CONNECT ON DATABASE coder TO grafana_ro;
GRANT USAGE ON SCHEMA public TO grafana_ro;
GRANT SELECT ON ALL TABLES IN SCHEMA public TO grafana_ro;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO grafana_ro;
PSQL

# ──────────────────────────────────────────────────────────────────────────────
# Gitea: admin + learner, clone repo, seed 5 issues, wire Actions + runner
# ──────────────────────────────────────────────────────────────────────────────
GITEA_ADMIN_USERNAME="gitadmin"
GITEA_ADMIN_PASSWORD="GiteaAdmin-$(date +%s | tail -c 6)!aA"
GITEA_ADMIN_EMAIL="gitadmin@coder.local"
LEARNER_USERNAME="learner"; LEARNER_PASSWORD="WorkshopL3arner!"; LEARNER_EMAIL="learner@coder.local"

docker compose exec -T -u git gitea gitea admin user create --username "${GITEA_ADMIN_USERNAME}" --password "${GITEA_ADMIN_PASSWORD}" --email "${GITEA_ADMIN_EMAIL}" --admin --must-change-password=false
docker compose exec -T -u git gitea gitea admin user create --username "${LEARNER_USERNAME}" --password "${LEARNER_PASSWORD}" --email "${LEARNER_EMAIL}" --must-change-password=false

# ── Gitea OIDC provider wiring (Coder's login provider) ───────────────────────
# Persist the Gitea admin creds (root-only) so C01's and C04's claim-time setups can PATCH
# the learner's identity and publish the CI target-user secret using admin auth.
umask 077
printf 'GITEA_ADMIN_USERNAME=%s\nGITEA_ADMIN_PASSWORD=%s\n' "${GITEA_ADMIN_USERNAME}" "${GITEA_ADMIN_PASSWORD}" > /etc/coder/gitea-admin.cred

# Register the OAuth2 application Coder uses as its OIDC client. Via cx (curl from inside the
# coder container straight to gitea:3000), so Caddy's X-WEBAUTH-USER header is bypassed and
# the gitadmin basic-auth applies. redirect_uri = Coder's PUBLIC OIDC callback.
OAUTH_APP_RESP=$(jq -n --arg n "coder" --arg r "${CODER_ACCESS_URL}/api/v2/users/oidc/callback" \
    '{name:$n, redirect_uris:[$r], confidential_client:true}' \
  | cx -s -X POST "${GITEA_INT}/api/v1/user/applications/oauth2" \
      -u "${GITEA_ADMIN_USERNAME}:${GITEA_ADMIN_PASSWORD}" -H "Content-Type: application/json" -d @-)
OIDC_CLIENT_ID=$(echo "$OAUTH_APP_RESP" | jq -r '.client_id // empty')
OIDC_CLIENT_SECRET=$(echo "$OAUTH_APP_RESP" | jq -r '.client_secret // empty')
[ -z "$OIDC_CLIENT_ID" ] && echo "WARN: Gitea OAuth2 app registration failed; OIDC login unavailable. Response: ${OAUTH_APP_RESP}"

# Issuer must match what Gitea advertises EXACTLY (trailing slash included). Read it from the
# discovery doc rather than guessing. Gitea derives the issuer from ROOT_URL (the public URL),
# so the value is correct even though we fetch discovery over the internal endpoint.
OIDC_ISSUER=$(cx -s "${GITEA_INT}/.well-known/openid-configuration" | jq -r '.issuer // empty')
[ -z "$OIDC_ISSUER" ] && OIDC_ISSUER="${GITEA_ACCESS_URL%/}"
echo "OIDC issuer resolved to: ${OIDC_ISSUER}"

# Write the OIDC env (the coder service's env_file target) and recreate coder to load it.
# Password auth stays enabled (the provisioning admin uses it). email_verified is ignored
# because Gitea may not mark a seeded account's email as verified. On first sign-in via
# "Sign in with Gitea", Coder JIT-creates the user from these claims (ALLOW_SIGNUPS=true).
# USERNAME_FIELD is the NAME claim (not preferred_username, which Gitea hard-wires to the local
# account name 'learner'). Coder's UsernameFrom() strips the disallowed chars from the claim, so
# "John Smith" -> "JohnSmith" (CamelCase, casing preserved). C01 paints that name onto the Gitea
# account at claim-time; with no participant details the account reports 'learner', so Coder
# derives the default username 'learner'.
if [ -n "$OIDC_CLIENT_ID" ] && [ -n "$OIDC_CLIENT_SECRET" ]; then
  cat > /etc/coder/coder-oidc.env <<OIDCENV
CODER_OIDC_ISSUER_URL=${OIDC_ISSUER}
CODER_OIDC_CLIENT_ID=${OIDC_CLIENT_ID}
CODER_OIDC_CLIENT_SECRET=${OIDC_CLIENT_SECRET}
CODER_OIDC_SCOPES=openid,profile,email
CODER_OIDC_ALLOW_SIGNUPS=true
CODER_OIDC_USERNAME_FIELD=name
CODER_OIDC_NAME_FIELD=name
CODER_OIDC_EMAIL_FIELD=email
CODER_OIDC_IGNORE_EMAIL_VERIFIED=true
CODER_OIDC_SIGN_IN_TEXT=Sign in with Gitea
CODER_DISABLE_PASSWORD_AUTH=false
OIDCENV
  docker compose up -d --force-recreate coder
  wait_in_coder "${CODER_INT}/healthz" 120 4 || echo "WARN: coder OIDC recreate gate timed out; continuing."
else
  # Break-glass: OIDC could not be configured (OAuth2 app registration or issuer resolution
  # failed, or the sandbox cannot reach its own public Gitea hostname). Without a fallback the
  # lab is unusable, since the local learner account was removed in favor of OIDC. So restore
  # a working local Coder login and surface its credentials, keeping the lab recoverable. This
  # only runs on the OIDC failure path, so the OIDC-first happy path is unaffected.
  echo "WARN: OIDC unavailable; provisioning a break-glass local learner account so sign-in still works."
  BG_LEARNER_EMAIL="learner@workshop.local"
  BG_LEARNER_USERNAME="learner"
  BG_LEARNER_PASSWORD="Learner-$(date +%s | tail -c 6)!aA"
  BG_RESP=$(cx -sS -w $'\n%{http_code}' -X POST "${CODER_INT}/api/v2/users" \
    -H "Coder-Session-Token: ${CODER_ADMIN_TOKEN}" -H "Content-Type: application/json" \
    -d "$(jq -n --arg e "$BG_LEARNER_EMAIL" --arg u "$BG_LEARNER_USERNAME" --arg p "$BG_LEARNER_PASSWORD" --arg o "$DEFAULT_ORG_ID" \
          '{email:$e, username:$u, password:$p, login_type:"password", organization_ids:[$o]}')")
  if [ "$(echo "$BG_RESP" | tail -n1)" = "201" ]; then
    agent variable set CODER_USER_EMAIL "${BG_LEARNER_EMAIL}"
    agent variable set CODER_USER_USERNAME "${BG_LEARNER_USERNAME}"
    agent variable set CODER_USER_PASSWORD "${BG_LEARNER_PASSWORD}"
    cat <<BGDIAG
=== BREAK-GLASS LOGIN ACTIVE (OIDC unavailable) ===
  "Sign in with Gitea" will not work. Direct the learner to sign in with:
    Email:    ${BG_LEARNER_EMAIL}
    Password: ${BG_LEARNER_PASSWORD}
  Root cause is almost always the sandbox not reaching its own public Gitea hostname over
  the OIDC back channel (see the OIDC issuer probe in the verification checklist).
===================================================
BGDIAG
  else
    echo "WARN: break-glass local learner creation failed: ${BG_RESP}. Lab may require manual login setup."
  fi
fi
# ── end Gitea OIDC provider wiring ────────────────────────────────────────────

printf '%s' '{"clone_addr":"https://github.com/coder-contrib/memory-card-ai-demo.git","repo_owner":"'"${LEARNER_USERNAME}"'","repo_name":"memory-card-ai-demo","mirror":false,"private":false,"description":"Memory Card Game — workshop repository"}' \
  | cx -s -X POST "${GITEA_INT}/api/v1/repos/migrate" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" -H "Content-Type: application/json" -d @- | head -c 200; echo

# Prune the migrated repo down to its default branch only. The migrate pulls coder-contrib's
# full branch set (claude-code/*, coder-fix/*, fix/issue-*, etc.); dropping them keeps the
# repo clean so the learner's/agent's branch is the ONLY non-main branch.
GREPO="${GITEA_INT}/api/v1/repos/${LEARNER_USERNAME}/memory-card-ai-demo"
# The migrate populates refs ASYNCHRONOUSLY — wait until the branch count is STABLE across two
# consecutive reads before pruning, otherwise we'd delete only 'main' and the rest arrive after.
prev=-1; stable=0
for i in $(seq 1 40); do
  cnt=$(cx -s "${GREPO}/branches?limit=100" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" 2>/dev/null | jq -r 'if type=="array" then length else 0 end' 2>/dev/null || echo 0)
  if [ "${cnt}" -ge 1 ] && [ "${cnt}" -eq "${prev}" ]; then stable=$((stable+1)); else stable=0; fi
  [ "${stable}" -ge 2 ] && break
  prev="${cnt}"; sleep 3
done
DEFAULT_BRANCH=$(cx -s "${GREPO}" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" 2>/dev/null | jq -r '.default_branch // "main"')
# Branch names contain slashes (claude-code/..., fix/...). The slash MUST be percent-encoded
# (/ → %2F) or Gitea's DELETE /branches/{branch} route 404s and the branch silently survives.
# Read the branch list into an ARRAY first. Piping into `while read` and calling `cx` (which is
# `docker compose exec ... curl`) in the loop body fails: exec drains the loop's stdin, so only
# the FIRST branch ever gets deleted. Iterating an array sidesteps that; </dev/null on the DELETE
# is belt-and-suspenders.
readarray -t PRUNE_BRANCHES < <(cx -s "${GREPO}/branches?limit=100" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" 2>/dev/null \
  | jq -r --arg d "${DEFAULT_BRANCH}" '.[]?.name | select(. != $d)')
for b in "${PRUNE_BRANCHES[@]}"; do
  [ -z "$b" ] && continue
  enc=$(printf '%s' "$b" | sed 's,/,%2F,g')
  cx -s -o /dev/null -X DELETE "${GREPO}/branches/${enc}" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" </dev/null || true
done
REMAIN=$(cx -s "${GREPO}/branches?limit=100" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" 2>/dev/null | jq -r '[.[]?.name] | join(",")')
echo "Branch prune complete. Remaining: ${REMAIN:-<none>} (default=${DEFAULT_BRANCH})"
# Snapshot the post-seed branch set as the C02 baseline. The C02 check passes ONLY when a branch
# exists BEYOND this baseline — so the check is honest even if a stray inherited branch lingers.
mkdir -p /etc/coder
cx -s "${GREPO}/branches?limit=100" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" 2>/dev/null \
  | jq -r '.[]?.name' | sort -u > /etc/coder/c02-branch-baseline.txt || true
echo "C02 branch baseline: $(tr '\n' ' ' < /etc/coder/c02-branch-baseline.txt)"

create_issue() { printf '%s' "$(jq -n --arg t "$1" --arg b "$2" '{title:$t, body:$b}')" \
  | cx -s -X POST "${GITEA_INT}/api/v1/repos/${LEARNER_USERNAME}/memory-card-ai-demo/issues" \
      -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" -H "Content-Type: application/json" -d @- >/dev/null; }
create_issue "Change the card back design" $'**Goal:** add a visible red diamond to the back face of each card; it disappears when a card is flipped face-up and reappears on a no-match flip-back.\n\n**Difficulty:** Easy (good first issue)'
create_issue "Add difficulty levels (4x4, 6x6, 8x8)" $'**Goal:** let the player pick a grid size before each game (Easy 4x4 / Medium 6x6 / Hard 8x8); grid + symbols scale; show current difficulty.\n\n**Difficulty:** Advanced'
create_issue "Implement high score persistence" $'**Goal:** track and persist the best score (fewest moves) across sessions; games-played counter increments.\n\n**Difficulty:** Intermediate'
create_issue "Create a theme selector" $'**Goal:** let the player pick a card-symbol theme (Animals, Emoji, Flags) before the game starts.\n\n**Difficulty:** Intermediate'
create_issue "Add a countdown timer" $'**Goal:** introduce a 60-second countdown lose condition with a "Time\'s Up!" modal; pauses on win, resets on reset.\n\n**Difficulty:** Intermediate'

# Append Gitea branch/PR guidance to the repo's AGENTS.md so the agent does its git work in the
# WORKSPACE against Gitea (origin), and opens PRs in Gitea — NOT on GitHub. The GitHub MCP is
# read-only (writes denied), so this is the agent's instruction set for where writes go.
AGENTS_JSON=$(cx -s "${GREPO}/contents/AGENTS.md" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" 2>/dev/null)
AGENTS_SHA=$(echo "$AGENTS_JSON" | jq -r '.sha // empty')
if [ -n "$AGENTS_SHA" ]; then
  AGENTS_CUR=$(echo "$AGENTS_JSON" | jq -r '.content' | base64 -d 2>/dev/null)
  AGENTS_GUIDE=$(cat <<'AGEOF'

## How to do git work in this environment (REQUIRED)

This repository's git host is **Gitea**, not GitHub. Your Coder workspace has it pre-cloned at
`/home/coder/memory-card-ai-demo` with the Gitea `origin` remote and credentials already set.

1. If no workspace is attached to this chat, **create one** and do all work inside it.
2. Implement the change, commit, and push your feature branch to Gitea: `git push -u origin <branch>`.
3. Open the pull request **in Gitea** (never on GitHub). Derive the base URL + credentials from the
   origin remote, then call the Gitea pulls API:
       REMOTE=$(git remote get-url origin)     # http://user:pass@host:8081/learner/memory-card-ai-demo.git
       BASE=${REMOTE%/learner/*}                # http://user:pass@host:8081
       curl -X POST -H "Content-Type: application/json" \
         -d '{"head":"<branch>","base":"main","title":"<title>","body":"<summary>"}' \
         "$BASE/api/v1/repos/learner/memory-card-ai-demo/pulls"

Do NOT create branches or pull requests on GitHub. All branches and PRs must live in Gitea.
AGEOF
)
  AGENTS_NEW_B64=$(printf '%s\n%s' "$AGENTS_CUR" "$AGENTS_GUIDE" | base64 -w0)
  jq -n --arg c "$AGENTS_NEW_B64" --arg s "$AGENTS_SHA" '{message:"Add Gitea workspace + PR guidance for agents", content:$c, sha:$s, branch:"main"}' \
    | cx -s -o /dev/null -X PUT "${GREPO}/contents/AGENTS.md" -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" -H "Content-Type: application/json" -d @- \
    && echo "AGENTS.md updated with Gitea PR guidance." || echo "WARN: AGENTS.md guidance update failed (non-fatal)."
else
  echo "WARN: AGENTS.md not found in repo; skipped Gitea guidance injection."
fi

# Seed the CI workflow into the repo (used by C04). Calls the Coder Agents API.
# Use a quoted heredoc to prevent shell expansion of ${{ }} GitHub Actions syntax,
# then selectively substitute only the three env vars via envsubst.
WF_TEMPLATE=$(cat <<'WFEOF'
name: coder-agent
on:
  workflow_dispatch:
    inputs:
      prompt:
        description: "Prompt for the Coder Agent"
        required: true
        default: "Clone the ${GITEA_ACCESS_URL}/${LEARNER_USERNAME}/memory-card-ai-demo.git repo and implement the 'Change the card back design' issue. Add a visible red diamond to the back face of every card that disappears when the card is flipped face-up. Create a feature branch named ci/card-back-design, commit your change, push the branch to origin, and open a pull request into main."
jobs:
  trigger-agent:
    runs-on: ubuntu-latest
    env:
      CODER_URL: ${CODER_ACCESS_URL}
      CODER_TARGET_USER_UUID: ${{ secrets.CODER_TARGET_USER_UUID }}
      CODER_SESSION_TOKEN: ${{ secrets.CODER_SESSION_TOKEN }}
      CODER_ORG_ID: ${{ secrets.CODER_ORG_ID }}
      PROMPT: ${{ github.event.inputs.prompt }}
    steps:
      - name: Trigger the Coder Agent
        id: trigger
        run: |
          echo "POST ${CODER_URL}/api/experimental/chats (org ${CODER_ORG_ID})"
          ESC=${PROMPT//\\/\\\\}
          ESC=${ESC//\"/\\\"}
          RESPONSE=$(curl -sS -X POST "${CODER_URL}/api/experimental/chats" \
            -H "Coder-Session-Token: ${CODER_SESSION_TOKEN}" \
            -H "Content-Type: application/json" \
            -d "{\"organization_id\":\"${CODER_ORG_ID}\",\"content\":[{\"type\":\"text\",\"text\":\"${ESC}\"}]}")

          CHAT_ID=$(echo "${RESPONSE}" | jq -r '.id')
          CHAT_URL="${CODER_URL}/agents/${CHAT_ID}"

          if [ -n "${CODER_TARGET_USER_UUID}" ]; then
            CHAT_ACL_RESP=$(curl -sS -w $'\n%{http_code}' -X PATCH \
              "${CODER_URL}/api/experimental/chats/${CHAT_ID}/acl" \
              -H "Coder-Session-Token: ${CODER_SESSION_TOKEN}" \
              -H "Content-Type: application/json" \
              -d "{\"user_roles\": {\"${CODER_TARGET_USER_UUID}\": \"read\"}}")
            CHAT_ACL_HTTP=$(echo "${CHAT_ACL_RESP}" | tail -n1)
            CHAT_ACL_BODY=$(echo "${CHAT_ACL_RESP}" | sed '$d')
            if [ "${CHAT_ACL_HTTP}" = "204" ]; then
              echo "Shared chat ${CHAT_ID} with ${CODER_TARGET_USER_UUID} (read)"
            else
              echo "WARN: could not share chat ${CHAT_ID} with ${CODER_TARGET_USER_UUID} (HTTP ${CHAT_ACL_HTTP}): ${CHAT_ACL_BODY}. The learner can still view it via the auditor role in C06." >&2
            fi
          else
            echo "No CODER_TARGET_USER_UUID set; skipping chat share (learner views it via the auditor role in C06)."
          fi

          echo "Chat created: ${CHAT_URL}"
          echo "chat_url=${CHAT_URL}" >> "${GITHUB_OUTPUT}"

      - name: Show chat URL
        run: echo "Chat URL is ${{ steps.trigger.outputs.chat_url }}"

      - name: Add to job summary
        run: |
          echo "### Coder Agent" >> "${GITHUB_STEP_SUMMARY}"
          echo "Chat: [${{ steps.trigger.outputs.chat_url }}](${{ steps.trigger.outputs.chat_url }})" >> "${GITHUB_STEP_SUMMARY}"
WFEOF
)

export GITEA_ACCESS_URL LEARNER_USERNAME CODER_ACCESS_URL
WF_B64=$(echo "${WF_TEMPLATE}" | envsubst '${GITEA_ACCESS_URL} ${LEARNER_USERNAME} ${CODER_ACCESS_URL}' | base64 -w0)

printf '%s' "$(jq -n --arg c "$WF_B64" '{message:"Add coder-agent CI workflow", content:$c, branch:"main"}')" \
  | cx -s -X POST "${GITEA_INT}/api/v1/repos/${LEARNER_USERNAME}/memory-card-ai-demo/contents/.gitea/workflows/coder-agent.yml" \
      -u "${LEARNER_USERNAME}:${LEARNER_PASSWORD}" -H "Content-Type: application/json" -d @- >/dev/null 2>&1 \
  || echo "WARN: workflow file seed failed (verify Gitea contents API)."

# Gitea Actions secrets the workflow needs: CODER_URL + CODER_SESSION_TOKEN + org id.
for kv in "CODER_URL=http://coder:7080" "CODER_SESSION_TOKEN=${CODER_CI_TOKEN}" "CODER_ORG_ID=${DEFAULT_ORG_ID}"; do
  k="${kv%%=*}"; v="${kv#*=}"
  printf '%s' "$(jq -n --arg d "$v" '{data:$d}')" \
    | cx -s -X PUT "${GITEA_INT}/api/v1/repos/${LEARNER_USERNAME}/memory-card-ai-demo/actions/secrets/${k}" \
        -u "${GITEA_ADMIN_USERNAME}:${GITEA_ADMIN_PASSWORD}" -H "Content-Type: application/json" -d @- >/dev/null 2>&1 || echo "WARN: Gitea Actions secret ${k} set failed."
done

# Mint a runner registration token and (re)start act_runner with it.
RUNNER_TOKEN=$(docker compose exec -T -u git gitea gitea actions generate-runner-token 2>/dev/null | tr -d '\r\n' || true)
if [ -n "${RUNNER_TOKEN}" ]; then
  echo "GITEA_RUNNER_TOKEN=${RUNNER_TOKEN}" > /etc/coder/.env
  docker compose up -d --force-recreate act_runner || echo "WARN: act_runner recreate failed."
  echo "act_runner registered."
else
  echo "WARN: could not mint Gitea runner token; C04 runner offline until registered (verify Gitea CLI)."
fi

# ──────────────────────────────────────────────────────────────────────────────
# Surface URLs + (Gitea) creds to challenge bodies via [[ Instruqt-Var ]]
# NOTE: no local-learner Coder creds — learners sign in via Gitea OIDC ("Sign in with Gitea").
# ──────────────────────────────────────────────────────────────────────────────
agent variable set SANDBOX_ID "${_SANDBOX_ID}"
agent variable set CODER_URL "${CODER_ACCESS_URL}"
agent variable set GITEA_URL "${GITEA_ACCESS_URL}"
agent variable set GITEA_USERNAME "${LEARNER_USERNAME}"
agent variable set GITEA_PASSWORD "${LEARNER_PASSWORD}"
agent variable set GITEA_REPO_URL "${GITEA_ACCESS_URL}/${LEARNER_USERNAME}/memory-card-ai-demo"
agent variable set GITEA_ISSUES_URL "${GITEA_ACCESS_URL}/${LEARNER_USERNAME}/memory-card-ai-demo/issues"
agent variable set GITEA_ACTIONS_URL "${GITEA_ACCESS_URL}/${LEARNER_USERNAME}/memory-card-ai-demo/actions"
agent variable set GRAFANA_URL "${GRAFANA_ACCESS_URL}"
agent variable set CODER_ADMIN_EMAIL "${CODER_ADMIN_EMAIL}"
agent variable set CODER_ADMIN_USERNAME "${CODER_ADMIN_USERNAME}"
agent variable set CODER_ADMIN_PASSWORD "${CODER_ADMIN_PASSWORD}"

echo "${CODER_ADMIN_TOKEN}" > /etc/coder/admin.token; chmod 600 /etc/coder/admin.token
echo "########## setup-workshop: complete ##########"

echo "HOSTNAME=$HOSTNAME"
hostname