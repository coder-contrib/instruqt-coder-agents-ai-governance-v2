#!/bin/bash
# Track-level setup for coder-agents-ai-governance  (REMEDIATED build — conforms to
# the approved "Coder Agents & AI Governance — Instruqt Track Build Plan").
#
# Stands up the full self-hosted stack on the workshop VM:
#   Coder control plane v2.34.6 (Agents + AI Gateway / AI Governance, trial-licensed)
#   Postgres (Coder state + AI Gateway audit tables: aibridge_*)
#   Gitea (local "GitHub": repo clone + issues + PRs + Actions)
#   act_runner (Gitea Actions runner, Docker mode — powers the C04 CI challenge)
#   Grafana (AI Gateway audit dashboard; Infinity plugin + cost table)
#   Caddy (reverse proxy; strips CSP/XFO for iframe embedding)
#
# AUTH: GitHub device-flow login (custom OAuth app) — learners sign in with their own
#   GitHub identity (real C06 attribution). The first-user is the LOCAL admin/owner
#   used for provisioning AND to activate the trial (which unlocks the AI Gateway).
#   Gitea stays on a LOCAL learner account.
# MODELS: Amazon Bedrock — Claude (native `bedrock` provider) + OpenAI gpt-oss-120b
#   (`openai-compat` provider → Bedrock's /openai/v1 endpoint w/ a minted Bedrock API
#   key). No external Anthropic/OpenAI account, no LiteLLM shim.
#
# RUNTIME-VERIFY (see MEMORY.md): exact Bedrock model IDs/inference profiles + region
#   for gpt-oss; short-term Bedrock API-key minting; AI-Gateway provider seed-env
#   schema; Agents↔Gateway wiring; Coder Agents / MCP registration endpoints; official
#   Grafana dashboard.json location; spend-cap API; Gitea Actions API for C04. Each
#   uncertain step falls through with a WARN and prints admin-UI target values so a
#   presenter can finish in <2 min. Each sandbox is a FRESH deployment, so seeding
#   providers from env on first boot is the supported once-off path.

set -euxo pipefail
PS4='+$0[$LINENO]+ '

echo "########## setup-workshop: starting ##########"
until [ -f /opt/instruqt/bootstrap/host-bootstrap-completed ]; do sleep 1; done
echo "host-bootstrap-completed sentinel found"

# ──────────────────────────────────────────────────────────────────────────────
# OS-layer prep
# ──────────────────────────────────────────────────────────────────────────────

wait_for_dpkg() {
  while fuser /var/lib/dpkg/lock-frontend /var/lib/apt/lists/lock >/dev/null 2>&1; do
    echo "Waiting for dpkg lock..."; sleep 2
  done
}
export DEBIAN_FRONTEND=noninteractive
export NEEDRESTART_MODE=a
wait_for_dpkg
apt-get update -qq
apt-get install -y -qq jq curl ca-certificates gnupg unzip python3 python3-pip

# ──────────────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────────────

retry_command() { local a=$1; shift; local d=$1; shift; local n=0
  until "$@"; do n=$((n+1)); [ "$n" -ge "$a" ] && { echo "retry_command: '$*' failed after ${a}"; return 1; }
    echo "retry_command attempt $n failed; sleep ${d}s"; sleep "$d"; d=$((d*2)); done; }

wait_http() { local url=$1; local rx=${2:-"^(200|302|401|403)$"}; local a=${3:-60}; local d=${4:-3}; local n=0
  while [ "$n" -lt "$a" ]; do local c; c=$(curl -s -o /dev/null -w "%{http_code}" "$url" || echo "000")
    echo "$c" | grep -qE "$rx" && { echo "wait_http: $url -> $c"; return 0; }; n=$((n+1)); sleep "$d"; done
  echo "wait_http: $url no ${rx} after ${a} attempts" >&2; return 1; }

# ──────────────────────────────────────────────────────────────────────────────
# Install Docker + Compose v2
# ──────────────────────────────────────────────────────────────────────────────

if ! command -v docker >/dev/null 2>&1; then
  install -m 0755 -d /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  chmod a+r /etc/apt/keyrings/docker.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list
  wait_for_dpkg; apt-get update -qq
  apt-get install -y -qq docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  systemctl enable --now docker
fi
docker --version; docker compose version
DOCKER_GID=$(stat -c %g /var/run/docker.sock)
echo "Docker socket GID: ${DOCKER_GID}"

# ──────────────────────────────────────────────────────────────────────────────
# Resolve injected credentials + model/region config
# ──────────────────────────────────────────────────────────────────────────────

set +x  # SECURITY: stop xtrace so secrets (AWS keys, Bedrock token, GitHub secrets) are NOT echoed to the Instruqt debug log
AWS_PREFIX="INSTRUQT_AWS_ACCOUNT_CODER_AGENTS_BEDROCK"
AWS_ACCESS_KEY_ID_VAL="$(printenv ${AWS_PREFIX}_AWS_ACCESS_KEY_ID || true)"
AWS_SECRET_ACCESS_KEY_VAL="$(printenv ${AWS_PREFIX}_AWS_SECRET_ACCESS_KEY || true)"
[ -z "${AWS_ACCESS_KEY_ID_VAL}" ] && echo "WARN: Bedrock AWS creds not found under ${AWS_PREFIX}_* — bedrock provider won't auth."

# Regions: Claude on us-east-1; gpt-oss on us-west-2 (AWS docs example region).
CLAUDE_REGION="${CLAUDE_REGION:-us-east-1}"
GPTOSS_REGION="${GPTOSS_REGION:-us-west-2}"

# Bedrock model identifiers.
# NOTE: Sonnet 4.6's Bedrock inference-profile ID has NO "-vN:0" suffix (unlike 4.5's
# "...-20250929-v1:0"). Probe 2026-06-14: "us.anthropic.claude-sonnet-4-6-v1:0" →
# ValidationException (invalid id); "us.anthropic.claude-sonnet-4-6" → AccessDenied(SCP)
# = the bare form IS a recognized inference profile. Confirm a live "hello" once the org
# SCP (p-46xnvut5) is lifted; if it then ValidationExceptions, fall back to
# us.anthropic.claude-sonnet-4-5-20250929-v1:0.
BEDROCK_SONNET_MODEL="${BEDROCK_SONNET_MODEL:-us.anthropic.claude-sonnet-4-6}"     # default
BEDROCK_HAIKU_MODEL="${BEDROCK_HAIKU_MODEL:-us.anthropic.claude-haiku-4-5-20251001-v1:0}"
BEDROCK_GPTOSS_MODEL="${BEDROCK_GPTOSS_MODEL:-openai.gpt-oss-120b-1:0}"

SPEND_CAP_USD_PER_DAY="${SPEND_CAP_USD_PER_DAY:-5}"   # total per-user/day; tuned to measured ~$0.37 full-run spend (~13x headroom)

# ──────────────────────────────────────────────────────────────────────────────
# Mint a short-term Bedrock API key (bearer) for the gpt-oss /openai/v1 path
# ──────────────────────────────────────────────────────────────────────────────
# RUNTIME-VERIFY: exact in-sandbox mechanism. Bedrock's OpenAI-compatible endpoint
# (/openai/v1) accepts ONLY a Bedrock bearer API key, not SigV4. We try the AWS
# bedrock token generator (short-term key from IAM creds); fall back to a stored
# long-term key in $BEDROCK_API_KEY if provided.
BEDROCK_API_KEY_VAL="${BEDROCK_API_KEY:-}"
if [ -z "${BEDROCK_API_KEY_VAL}" ] && [ -n "${AWS_ACCESS_KEY_ID_VAL}" ]; then
  pip install --quiet --break-system-packages aws-bedrock-token-generator boto3 2>/dev/null || true
  BEDROCK_API_KEY_VAL="$(AWS_ACCESS_KEY_ID="${AWS_ACCESS_KEY_ID_VAL}" \
    AWS_SECRET_ACCESS_KEY="${AWS_SECRET_ACCESS_KEY_VAL}" AWS_REGION="${GPTOSS_REGION}" \
    python3 - <<'PY' 2>/dev/null || true
try:
    from aws_bedrock_token_generator import provide_token
    print(provide_token(region="us-west-2"))
except Exception as e:
    pass
PY
)"
fi
[ -z "${BEDROCK_API_KEY_VAL}" ] && echo "WARN: could not mint a Bedrock API key — gpt-oss (openai-compat) provider will need a BEDROCK_API_KEY secret. Claude (bedrock provider) is unaffected."
set -x  # resume xtrace (secrets handled above)

# ──────────────────────────────────────────────────────────────────────────────
# Compute sandbox-public URLs
# ──────────────────────────────────────────────────────────────────────────────

CODER_ACCESS_URL="https://workshop-80-${_SANDBOX_ID}.env.play.instruqt.com"
GITEA_ACCESS_URL="https://workshop-8081-${_SANDBOX_ID}.env.play.instruqt.com"
GRAFANA_ACCESS_URL="https://workshop-3001-${_SANDBOX_ID}.env.play.instruqt.com"
# Setup-time HTTP runs INSIDE the coder container (it has curl and sits on coder-net),
# hitting internal service endpoints. This bypasses BOTH failure modes seen in prior
# runs: the public proxy's high-port routes return 572 during setup, AND the lifecycle
# script is NOT in the Docker host's network namespace (published-port localhost → 000,
# curl exit 7). coder→localhost:7080, coder→gitea:3000, coder→grafana:3000 are always
# reachable. Public *_ACCESS_URL vars stay for the container access URL, Gitea ROOT_URL,
# learner browser tabs, and [[ Instruqt-Var ]] links.
CODER_INT="http://localhost:7080"   # coder, from inside the coder container
GITEA_INT="http://gitea:3000"       # gitea, reachable from coder over coder-net
GRAFANA_INT="http://grafana:3000"   # grafana, reachable from coder over coder-net
# cx: run curl inside the coder container. Pipe JSON request bodies via stdin (-d @-).
cx() { docker compose -f /etc/coder/docker-compose.yml exec -T coder curl "$@"; }
# wait_in_coder URL ATTEMPTS DELAY — readiness probe issued from inside the coder container.
wait_in_coder() {
  local u="$1" a="$2" d="$3" n=0
  while [ "$n" -lt "$a" ]; do
    if docker compose -f /etc/coder/docker-compose.yml exec -T coder curl -sf -o /dev/null "$u"; then
      echo "wait_in_coder: ${u} ready"; return 0; fi
    n=$((n+1)); sleep "$d"
  done
  echo "wait_in_coder: ${u} not ready after ${a} attempts"; return 1
}
echo "CODER=${CODER_ACCESS_URL} GITEA=${GITEA_ACCESS_URL} GRAFANA=${GRAFANA_ACCESS_URL}"

# ──────────────────────────────────────────────────────────────────────────────
# Generate stack config files
# ──────────────────────────────────────────────────────────────────────────────

mkdir -p /etc/coder /etc/coder/grafana/provisioning/datasources \
         /etc/coder/grafana/provisioning/dashboards /etc/coder/grafana/dashboards

# Caddyfile — three listeners, CSP/XFO stripped.
cat > /etc/coder/Caddyfile <<'EOF'
{
    auto_https off
}
:80 {
    reverse_proxy coder:7080 {
        header_down -X-Frame-Options
        header_down -Content-Security-Policy
    }
}
:8081 {
    # OIDC back-channel endpoints Coder calls server-to-server (with the client secret and
    # the bearer token). These MUST authenticate as themselves, so do NOT force a user
    # header on them, or Gitea would resolve them as 'learner' and the token/userinfo
    # exchange can misbehave. Exact-path match; /login/oauth/authorize is intentionally
    # excluded so the browser authorize step still rides the reverse-proxy auth below.
    @oidc_backchannel path /login/oauth/access_token /login/oauth/userinfo /login/oauth/keys
    handle @oidc_backchannel {
        reverse_proxy gitea:3000 {
            header_down -X-Frame-Options
            header_down -Content-Security-Policy
        }
    }
    # Everything else (the Gitea UI and the /login/oauth/authorize page): present every
    # request as the local 'learner' account via Gitea reverse-proxy auth. header_up SETS
    # (replaces) the value, so a client can't spoof a different user through Caddy. This
    # removes the "Sign in" button, gives the embedded tab write access, and makes the
    # "Sign in with Gitea" handoff in Coder seamless (the authorize page is pre-authed).
    handle {
        reverse_proxy gitea:3000 {
            header_down -X-Frame-Options
            header_down -Content-Security-Policy
            header_up X-WEBAUTH-USER learner
        }
    }
}
:3001 {
    reverse_proxy grafana:3000 {
        header_down -X-Frame-Options
        header_down -Content-Security-Policy
    }
}
EOF

# Grafana datasources: Postgres (read-only, aibridge_*) + Infinity (LiteLLM model-pricing
# JSON for the cost table). Matches plan §3.
cat > /etc/coder/grafana/provisioning/datasources/datasources.yaml <<'EOF'
apiVersion: 1
datasources:
  # UIDs deliberately match the datasource inputs in Coder's OFFICIAL aibridge
  # dashboard.json (coder-observability-ro / litellm-pricing-data) so it provisions
  # with no remapping. The Postgres role stays grafana_ro (read-only).
  - name: Coder AI Gateway (Postgres)
    uid: coder-observability-ro
    type: grafana-postgresql-datasource
    access: proxy
    url: postgres:5432
    user: grafana_ro
    secureJsonData:
      password: "grafana_ro_pw"
    jsonData: { database: coder, sslmode: disable, postgresVersion: 1600 }
    isDefault: true
    editable: false
  - name: Model Pricing (Infinity)
    uid: litellm-pricing-data
    type: yesoreyeram-infinity-datasource
    access: proxy
    url: https://raw.githubusercontent.com/BerriAI/litellm/refs/heads/main/model_prices_and_context_window.json
    editable: false
EOF

cat > /etc/coder/grafana/provisioning/dashboards/dashboards.yaml <<'EOF'
apiVersion: 1
providers:
  - name: AI Gateway
    orgId: 1
    folder: ''
    type: file
    options: { path: /var/lib/grafana/dashboards }
EOF

# Coder's OFFICIAL aibridge Grafana dashboard (Build Plan §5: "Coder's official
# dashboard.json, not a custom build"). Source: coder/coder
#   examples/monitoring/dashboards/grafana/aibridge/dashboard.json
# Pinned to the reviewed blob (sha 25ec3ba...) via the GitHub blobs API; falls back to
# main, then to a minimal embedded dashboard so the tab is never empty.
# It's an EXPORTED dashboard (uses ${DS_*} template inputs), so we (1) resolve the two
# datasource placeholders to our provisioned UIDs, (2) drop the import-only
# __inputs/__elements/__requires, and (3) force a stable uid + branded title so the
# Grafana tab deep-link (/d/coder-ai-gateway) and the C06 nav copy stay correct.
DASH_RAW="/etc/coder/grafana/dashboards/.ai-gateway.raw.json"
DASH_OUT="/etc/coder/grafana/dashboards/ai-gateway.json"
DASH_SRCS=(
  "blob|https://api.github.com/repos/coder/coder/git/blobs/25ec3ba167215accecdc6bc30de1887836c0ec8b"
  "raw|https://raw.githubusercontent.com/coder/coder/main/examples/monitoring/dashboards/grafana/aibridge/dashboard.json"
)
DASH_OK=""
for entry in "${DASH_SRCS[@]}"; do
  kind="${entry%%|*}"; url="${entry#*|}"
  if [ "$kind" = "blob" ]; then
    curl -fsSL -H "Accept: application/vnd.github.raw" "$url" -o "$DASH_RAW" 2>/dev/null || continue
  else
    curl -fsSL "$url" -o "$DASH_RAW" 2>/dev/null || continue
  fi
  jq -e . "$DASH_RAW" >/dev/null 2>&1 || continue
  # Resolve the exported template datasource placeholders -> our provisioned UIDs.
  sed -i 's/\${DS_CODER-OBSERVABILITY-RO}/coder-observability-ro/g; s/\${DS_LITELLM-PRICING-DATA}/litellm-pricing-data/g' "$DASH_RAW"
  if jq 'del(.__inputs, .__elements, .__requires) | .id=null | .uid="coder-ai-gateway" | .title="Coder AI Gateway — Audit & Attribution"' \
        "$DASH_RAW" > "$DASH_OUT" 2>/dev/null; then
    echo "Official aibridge dashboard provisioned (source: $kind)."; DASH_OK=1; rm -f "$DASH_RAW"; break
  fi
done
if [ -z "${DASH_OK}" ]; then
  echo "WARN: official aibridge dashboard not fetched — using embedded fallback."
  cat > "$DASH_OUT" <<'EOF'
{ "title": "Coder AI Gateway — Audit & Attribution", "uid": "coder-ai-gateway", "schemaVersion": 39, "version": 1,
  "time": {"from":"now-7d","to":"now"}, "refresh": "1m", "panels": [
   {"type":"stat","title":"Total intercepted requests","gridPos":{"h":6,"w":8,"x":0,"y":0},
    "datasource":{"type":"grafana-postgresql-datasource","uid":"coder-observability-ro"},
    "targets":[{"rawSql":"SELECT count(*) AS value FROM aibridge_interceptions;","format":"table","refId":"A"}]},
   {"type":"table","title":"Requests by user","gridPos":{"h":10,"w":16,"x":8,"y":0},
    "datasource":{"type":"grafana-postgresql-datasource","uid":"coder-observability-ro"},
    "targets":[{"rawSql":"SELECT coalesce(NULLIF(u.name, ''), u.username) AS user, count(*) AS requests FROM aibridge_interceptions i JOIN users u ON i.initiator_id = u.id GROUP BY 1 ORDER BY requests DESC;","format":"table","refId":"A"}]},
   {"type":"timeseries","title":"Interceptions over time","gridPos":{"h":8,"w":24,"x":0,"y":10},
    "datasource":{"type":"grafana-postgresql-datasource","uid":"coder-observability-ro"},
    "targets":[{"rawSql":"SELECT date_trunc('minute', started_at) AS time, count(*) AS interceptions FROM aibridge_interceptions WHERE $__timeFilter(started_at) GROUP BY 1 ORDER BY 1;","format":"time_series","refId":"A"}]}
  ]}
EOF
fi

# Gitea act_runner registration token is minted AFTER Gitea is up (see below); the
# runner reads it from /etc/coder/.env. Seed a placeholder so the first compose-up
# doesn't choke; we recreate act_runner once the real token exists.
echo "GITEA_RUNNER_TOKEN=pending" > /etc/coder/.env

# Seed an empty OIDC env file so the coder service's env_file bind exists on the first
# compose-up. Real CODER_OIDC_* values are written once Gitea and its OAuth2 app are ready
# (see the Gitea block below), after which coder is recreated to pick them up.
: > /etc/coder/coder-oidc.env

# Docker Compose stack.
cat > /etc/coder/docker-compose.yml <<EOF
networks: { coder-net: { driver: bridge, name: coder-net } }
volumes: { postgres-data: {}, gitea-data: {}, coder-data: {}, grafana-data: {} }
services:
  postgres:
    image: postgres:16
    environment: { POSTGRES_USER: coder, POSTGRES_PASSWORD: coder, POSTGRES_DB: coder }
    volumes: [ "postgres-data:/var/lib/postgresql/data" ]
    networks: [coder-net]
    restart: unless-stopped

  coder:
    image: ghcr.io/coder/coder:v2.34.6
    depends_on: [postgres]
    # OIDC login config (Gitea as the identity provider) is written to this file AFTER
    # Gitea is up and the OAuth2 app exists, then coder is recreated to load it. The file
    # is seeded empty before the first compose-up so this bind mount always exists.
    env_file:
      - /etc/coder/coder-oidc.env
    environment:
      CODER_PG_CONNECTION_URL: postgresql://coder:coder@postgres/coder?sslmode=disable
      CODER_HTTP_ADDRESS: 0.0.0.0:7080
      CODER_ACCESS_URL: ${CODER_ACCESS_URL}
      CODER_WILDCARD_ACCESS_URL: ""
      # Telemetry ON: the trial/AI-Governance license REQUIRES telemetry — with it
      # disabled the UI shows "License requires telemetry but telemetry is disabled"
      # and the Coder Agents entitlement appears degraded (model dropdown stays empty).
      CODER_TELEMETRY_ENABLE: "true"
      CODER_OAUTH2_GITHUB_DEFAULT_PROVIDER_ENABLE: "false"
      # ── AWS creds for the native bedrock provider (Claude) ──
      AWS_ACCESS_KEY_ID: "${AWS_ACCESS_KEY_ID_VAL}"
      AWS_SECRET_ACCESS_KEY: "${AWS_SECRET_ACCESS_KEY_VAL}"
      AWS_DEFAULT_REGION: "${CLAUDE_REGION}"
      AWS_REGION: "${CLAUDE_REGION}"
      # ── AI Gateway (aibridge) ──────────────────────────────────────────────
      # Correct namespace is CODER_AIBRIDGE_* (NOT CODER_AI_GATEWAY_*, which is the
      # deprecated DB-seed namespace that fails the boot). The gateway MUST be
      # explicitly enabled. NOTE: these env vars only PRE-SEED the DB on first boot
      # (deprecated, ignored after upgrades). The Claude provider is created via the
      # REST API below as TYPE=bedrock — env-seeding Bedrock as TYPE=anthropic does
      # NOT surface its models in the Agents chat dropdown (confirmed 2026-06-15).
      # Indices contiguous from 0; each NAME unique.
      CODER_AIBRIDGE_ENABLED: "true"
      # Provider 0: gpt-oss via Bedrock's OpenAI-compatible endpoint. TYPE=openai
      # takes KEY (the minted Bedrock bearer token) + BASE_URL. Model picked per-request.
      CODER_AIBRIDGE_PROVIDER_0_TYPE: "openai"
      CODER_AIBRIDGE_PROVIDER_0_NAME: "bedrock-gptoss"
      CODER_AIBRIDGE_PROVIDER_0_KEY: "${BEDROCK_API_KEY_VAL}"
      CODER_AIBRIDGE_PROVIDER_0_BASE_URL: "https://bedrock-runtime.${GPTOSS_REGION}.amazonaws.com/openai/v1"
    volumes:
      - "coder-data:/home/coder/.config"
      - "/var/run/docker.sock:/var/run/docker.sock"
    group_add: [ "${DOCKER_GID}" ]
    networks: [coder-net]
    restart: unless-stopped

  gitea:
    image: gitea/gitea:latest
    environment:
      USER_UID: "1000"
      USER_GID: "1000"
      GITEA__server__ROOT_URL: ${GITEA_ACCESS_URL}/
      GITEA__server__DOMAIN: workshop
      GITEA__server__DISABLE_SSH: "true"
      GITEA__security__INSTALL_LOCK: "true"
      GITEA__service__DISABLE_REGISTRATION: "true"
      GITEA__service__REQUIRE_SIGNIN_VIEW: "false"
      # Transparent sign-in: trust the X-WEBAUTH-USER header Caddy injects and log every
      # request in as that local account (the 'learner' user). No "Sign in" button; the
      # embedded Gitea tab is always authenticated with write access.
      GITEA__service__ENABLE_REVERSE_PROXY_AUTHENTICATION: "true"
      GITEA__service__ENABLE_REVERSE_PROXY_AUTHENTICATION_API: "true"
      # Gitea only honors the auth header from a trusted proxy. Gitea is reachable ONLY
      # via Caddy (its port isn't published), so trust the sandbox's internal network.
      GITEA__security__REVERSE_PROXY_TRUSTED_PROXIES: "*"
      # Display the participant's full name (painted onto the 'learner' account by C01) instead
      # of the 'learner' username wherever Gitea renders a user identity (dashboard greeting,
      # avatar menu, profile, issue/PR authorship). Falls back to the username when the full name
      # is empty (the no-details case), so the default identity stays 'learner'.
      GITEA__ui__DEFAULT_SHOW_FULL_NAME: "true"
      GITEA__actions__ENABLED: "true"
      GITEA__database__DB_TYPE: sqlite3
      GITEA__database__PATH: /data/gitea/gitea.db
    volumes: [ "gitea-data:/data" ]
    networks: [coder-net]
    restart: unless-stopped

  act_runner:
    image: gitea/act_runner:latest
    depends_on: [gitea]
    environment:
      GITEA_INSTANCE_URL: "http://gitea:3000"
      GITEA_RUNNER_REGISTRATION_TOKEN: "\${GITEA_RUNNER_TOKEN}"
      GITEA_RUNNER_NAME: "workshop-runner"
      CONFIG_FILE: "/config.yaml"
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
      - "/etc/coder/act_runner.yaml:/config.yaml:ro"
    networks: [coder-net]
    restart: unless-stopped

  grafana:
    image: grafana/grafana:latest
    environment:
      GF_INSTALL_PLUGINS: "yesoreyeram-infinity-datasource"
      GF_AUTH_ANONYMOUS_ENABLED: "true"
      GF_AUTH_ANONYMOUS_ORG_ROLE: "Viewer"
      GF_AUTH_DISABLE_LOGIN_FORM: "true"
      GF_SECURITY_ALLOW_EMBEDDING: "true"
      GF_USERS_DEFAULT_THEME: "dark"
    volumes:
      - "grafana-data:/var/lib/grafana"
      - "/etc/coder/grafana/provisioning:/etc/grafana/provisioning:ro"
      - "/etc/coder/grafana/dashboards:/var/lib/grafana/dashboards:ro"
    networks: [coder-net]
    restart: unless-stopped

  caddy:
    image: caddy:2
    depends_on: [coder, gitea, grafana]
    volumes: [ "/etc/coder/Caddyfile:/etc/caddy/Caddyfile:ro" ]
    ports: [ "80:80", "8081:8081", "3001:3001" ]
    networks: [coder-net]
    restart: unless-stopped
EOF

# act_runner config: attach Actions job containers to coder-net so the CI job
# (C04) can resolve "coder:7080". Without this, jobs land on an ephemeral per-job
# network and can't reach the control plane. Also map host.docker.internal as a
# fallback. Must exist as a FILE before the first `docker compose up` (bind mount).
cat > /etc/coder/act_runner.yaml <<'EOF'
container:
  network: "coder-net"
  options: "--add-host=host.docker.internal:host-gateway"
  valid_volumes: []
  force_pull: false
EOF

# ──────────────────────────────────────────────────────────────────────────────
# Pre-pull images in parallel (incl. act_runner + workspace base)
# ──────────────────────────────────────────────────────────────────────────────
echo "Pre-pulling images..."
for img in postgres:16 ghcr.io/coder/coder:v2.34.6 gitea/gitea:latest gitea/act_runner:latest \
           grafana/grafana:latest caddy:2 codercom/enterprise-base:ubuntu; do
